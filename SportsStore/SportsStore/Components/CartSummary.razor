@using SportsStore.Services
@using SportsStore.Client.Services
@using SportsStore.Client.Models
@inject CartStateService CartState
@inject NavigationManager NavigationManager
@implements IDisposable
@rendermode InteractiveServer

<div class="d-flex align-items-center">
    @if (CartState.Cart.Lines.Any())
    {
        <small class="text-white me-3 d-none d-sm-block">
            <b>Your cart:</b>
            <span class="badge badge-custom ms-1">@CartState.Cart.Lines.Sum(x => x.Quantity) item(s)</span>
            <span class="ms-2 fw-semibold" style="color: var(--primary); font-size: 1.05rem;">
                $@CartState.Cart.ComputeTotalValue().ToString("F2")
            </span>
        </small>
    }
    else
    {
        <small class="text-muted me-3 d-none d-sm-block">Your cart is empty</small>
    }
    <button class="btn btn-accent-custom px-3 py-2 d-flex align-items-center position-relative" @onclick="ToggleCart">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="bi bi-cart me-2" viewBox="0 0 16 16">
            <path d="M0 1.5A.5.5 0 0 1 .5 1H2a.5.5 0 0 1 .485.379L2.89 3H14.5a.5.5 0 0 1 .491.592l-1.5 8A.5.5 0 0 1 13 12H4a.5.5 0 0 1-.491-.408L2.01 3.607 1.61 2H.5a.5.5 0 0 1-.5-.5zM3.102 4l1.313 7h8.17l1.313-7H3.102zM5 12a2 2 0 1 0 0 4 2 2 0 0 0 0-4zm7 0a2 2 0 1 0 0 4 2 2 0 0 0 0-4zm-7 1a1 1 0 1 1 0 2 1 1 0 0 1 0-2zm7 0a1 1 0 1 1 0 2 1 1 0 0 1 0-2z"/>
        </svg>
        Cart
        @if (CartState.Cart.Lines.Any())
        {
            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                @CartState.Cart.Lines.Sum(x => x.Quantity)
            </span>
        }
    </button>
</div>

<!-- Sliding Cart Side-Drawer Overlay -->
@if (isCartOpen)
{
    <div class="drawer-backdrop" @onclick="ToggleCart">
        <div class="drawer-custom p-4 d-flex flex-column h-100" @onclick:stopPropagation>
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h3 class="text-white mb-0">Your Basket</h3>
                <button class="btn-close-custom" @onclick="ToggleCart">×</button>
            </div>

            @if (!CartState.Cart.Lines.Any())
            {
                <div class="flex-grow-1 d-flex flex-column justify-content-center align-items-center text-center">
                    <p class="text-muted fs-5 mb-4">Your basket is currently empty.</p>
                    <button class="btn btn-primary-custom" @onclick="ToggleCart">Continue Shopping</button>
                </div>
            }
            else
            {
                <div class="flex-grow-1 overflow-auto pe-2 mb-4">
                    @foreach (var line in CartState.Cart.Lines)
                    {
                        <div class="drawer-item mb-3 p-3 rounded-3 d-flex align-items-center justify-content-between">
                            <div class="me-3">
                                <h6 class="text-white mb-1">@line.Product.Name</h6>
                                <span class="text-muted small">$@line.Product.Price.ToString("F2") each</span>
                            </div>
                            <div class="d-flex align-items-center gap-3">
                                <div class="input-group input-group-sm" style="max-width: 100px;">
                                    <button class="btn btn-outline-secondary" type="button" @onclick="() => UpdateQuantity(line.Product, -1)">-</button>
                                    <span class="input-group-text bg-dark border-secondary text-white px-2">@line.Quantity</span>
                                    <button class="btn btn-outline-secondary" type="button" @onclick="() => UpdateQuantity(line.Product, 1)">+</button>
                                </div>
                                <button class="btn btn-link text-danger p-0 ms-2" style="font-size: 1.25rem;" @onclick="() => RemoveLine(line.Product)">
                                    &times;
                                </button>
                            </div>
                        </div>
                    }
                </div>

                <div class="border-top border-secondary pt-4">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span class="text-muted">Subtotal:</span>
                        <span class="fs-4 fw-bold text-accent" style="color: var(--accent);">$@CartState.Cart.ComputeTotalValue().ToString("F2")</span>
                    </div>
                    <button class="btn btn-accent-custom w-100 py-3 fw-bold text-uppercase mb-2" @onclick="GoToCheckout">
                        Checkout Now
                    </button>
                    <button class="btn btn-outline-secondary w-100 py-2 text-white" style="border-color: var(--border-color);" @onclick="ClearCart">
                        Clear Basket
                    </button>
                </div>
            }
        </div>
    </div>
}

@code {
    private bool isCartOpen = false;

    protected override void OnInitialized()
    {
        CartState.OnChange += StateHasChanged;
        CartState.OnItemAdded += OpenCartDrawer;
    }

    private void OpenCartDrawer()
    {
        isCartOpen = true;
        StateHasChanged();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && CartState is SessionCartStateService sessionCart)
        {
            await sessionCart.LoadCartAsync();
            StateHasChanged();
        }
    }

    private void ToggleCart()
    {
        isCartOpen = !isCartOpen;
    }

    private async Task UpdateQuantity(Product product, int amount)
    {
        var line = CartState.Cart.Lines.FirstOrDefault(l => l.ProductId == product.ProductId);
        if (line != null)
        {
            int newQuantity = line.Quantity + amount;
            if (newQuantity <= 0)
            {
                CartState.RemoveLine(product);
            }
            else
            {
                CartState.UpdateQuantity(product, newQuantity);
            }
            if (CartState is SessionCartStateService sessionCart)
            {
                await sessionCart.SaveCartAsync();
            }
        }
    }

    private async Task RemoveLine(Product product)
    {
        CartState.RemoveLine(product);
        if (CartState is SessionCartStateService sessionCart)
        {
            await sessionCart.SaveCartAsync();
        }
    }

    private async Task ClearCart()
    {
        CartState.Clear();
        if (CartState is SessionCartStateService sessionCart)
        {
            await sessionCart.SaveCartAsync();
        }
    }

    private void GoToCheckout()
    {
        isCartOpen = false;
        NavigationManager.NavigateTo("/checkout");
    }

    public void Dispose()
    {
        CartState.OnChange -= StateHasChanged;
        CartState.OnItemAdded -= OpenCartDrawer;
    }
}
