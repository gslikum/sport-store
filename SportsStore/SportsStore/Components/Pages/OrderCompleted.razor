@page "/order-completed/{orderId:long}"
@rendermode InteractiveServer

@inject IStoreRepository Repository

<PageTitle>Order Completed</PageTitle>

<div class="row justify-content-center text-center">
    <div class="col-md-6">
        <div class="card-custom p-5">
            <div class="mb-4">
                <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" fill="var(--accent)" class="bi bi-check-circle" viewBox="0 0 16 16">
                    <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z"/>
                    <path d="M10.97 4.97a.235.235 0 0 0-.02.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-1.071-1.05z"/>
                </svg>
            </div>
            
            <h2 class="text-white mb-3">Thanks for your order!</h2>
            <p class="text-muted mb-4">We've received your request and will ship your products shortly.</p>
            
            <div class="bg-dark p-3 rounded mb-4 text-start border border-secondary">
                <p class="text-white mb-2"><b>Order ID:</b> #@OrderId</p>
                @if (order != null)
                {
                    <p class="text-white mb-2"><b>Shipping to:</b> @order.Name</p>
                    <p class="text-muted mb-0">@order.Line1, @order.City, @order.State, @order.Country</p>
                }
            </div>

            <a href="/" class="btn btn-primary-custom px-5 py-2">
                Return to Shop
            </a>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public long OrderId { get; set; }

    private Order? order;

    protected override void OnInitialized()
    {
        order = Repository.Orders.FirstOrDefault(o => o.OrderId == OrderId);
    }
}
