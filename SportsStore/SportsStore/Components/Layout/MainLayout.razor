@inherits LayoutComponentBase

<div class="header-glass py-2 px-4 mb-4">
    <div class="container-fluid d-flex justify-content-between align-items-center">
        <div class="d-flex align-items-center">
            <a href="/" class="text-decoration-none d-flex align-items-center">
                <img src="/images/logo.png" alt="Voltics Logo" style="height: 45px; width: 45px; object-fit: contain; margin-right: 12px;" />
                <span class="fs-3 fw-bold text-white" style="letter-spacing: 1px; font-family: 'Outfit', sans-serif;">
                    VOLTICS<span style="color: var(--primary);">STORE</span>
                </span>
            </a>
        </div>
        <CartSummary />
    </div>
</div>

<div class="container-fluid px-4 pb-5">
    @Body
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
